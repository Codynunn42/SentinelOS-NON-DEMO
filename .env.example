# SentinelOS NON-DEMO environment template
# COMM: Sentinel AI by Cody Nunn | Nunn Cloud

PORT=3000
SENTINEL_API_KEY=replace-with-secure-api-key
DATABASE_URL=postgres://user:password@host:5432/sentinelos
NODE_ENV=production

# Deployment tier classification
# Options: PUBLIC | ENTERPRISE | GOVERNMENT | SOVEREIGN
# Leave unset to default to PUBLIC
SENTINEL_DEPLOYMENT_TIER=PUBLIC

# Sovereign mode
# Set to 1 to require a valid sovereign license file at startup
SENTINEL_SOVEREIGN_MODE=0
SENTINEL_LICENSE_FILE=./sentinel.license.json
SENTINEL_LICENSE_KEY=replace-with-license-verification-key

# Sovereign license generation (never commit — operator use only)
SENTINEL_LICENSE_SIGNING_KEY=replace-with-your-private-signing-key
SOVEREIGN_LICENSE_ID=SOS-2026-0001
SOVEREIGN_ISSUED_TO=Organization Name
SOVEREIGN_CAPABILITIES=execute,audit,govern,drift

# Government mode
SENTINEL_GOV_MODE=0

# Stripe checkout ingestion
# Keep disabled until product/price/legal approval is complete.
SENTINEL_STRIPE_CHECKOUT_ENABLED=0
SENTINEL_PUBLIC_BASE_URL=https://ca-nc-dev-sentinel.calmhill-388e1d39.eastus2.azurecontainerapps.io
STRIPE_PUBLISHABLE_KEY=pk_live_or_test_value
STRIPE_SECRET_KEY=sk_live_or_test_value
STRIPE_PRICE_ID=price_replace_me
STRIPE_API_VERSION=2026-04-22.dahlia
